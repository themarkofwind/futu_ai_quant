# 复制为 .env 后填入真实值：
#   cp .env.example .env

# ---------- DeepSeek ----------
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---------- LLM 多提供商（可选）----------
# LLM_PROVIDER=deepseek   # deepseek | openai | anthropic | gemini | custom
# LLM_MODEL=deepseek-v4-flash   # 留空则用提供商默认；DeepSeek 亦可选 deepseek-v4-pro
# LLM_API_KEY=            # 通用 Key（custom 时使用）
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=8192
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=your_google_ai_studio_api_key
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-3.5-flash   # Gemini 默认；亦可 gemini-2.5-flash / gemini-3.1-flash-lite-preview

# ---------- Futu OpenD ----------
FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111

# 实盘查询持仓/下单时需要（模拟盘可不填）
# FUTU_TRADE_UNLOCK_PWD=your_trade_unlock_password

# ---------- 分析间隔（可选）----------
# 0 = 自动：港股交易时段 30 分钟，非交易时段 4 小时
ANALYSIS_INTERVAL_SEC=0
INTRADAY_INTERVAL_SEC=1800
OFFHOURS_INTERVAL_SEC=14400

# 日K量比过滤：session_adjusted（默认，盘中折算）| raw | close_only
# VOLUME_FILTER=session_adjusted

# 卖权单次上限（0=仅受备兑股数限制）
# MAX_OPTION_CONTRACTS_PER_TRADE=0
# IV 历史快照目录（用于计算历史 IV Rank）
# IV_HISTORY_MIN_SAMPLES=10

# 分层阈值（%）
# DEEP_LOSS_THRESHOLD=-50
# MODERATE_LOSS_THRESHOLD=0

# 期权行权价扫描：现价 ± ATR 倍数（无 ATR 时回退固定百分比）
# OPTION_STRIKE_ATR_MULT_LOW=0.5
# OPTION_STRIKE_ATR_MULT_HIGH=2.0

# 单票市值占比上限（%），超出写入 portfolio_risk.concentration_alerts
# PORTFOLIO_MAX_SINGLE_WEIGHT_PCT=40

# ---------- 宏观风险 overlay（可选）----------
# MACRO_CALENDAR_PATH=data/macro_calendar.json
# MACRO_RISK_ENABLED=1
# MACRO_HSI_CODE=HK.800000
# MACRO_GOLD_CODE=HK.02840
# MACRO_HSI_5D_DROP_PCT=-5
# MACRO_HSI_TODAY_DROP_PCT=-2.5
# MACRO_GOLD_5D_RISE_PCT=3
# MACRO_FED_BLACKOUT_DAYS=2
# MACRO_SWING_MULTIPLIER_ELEVATED=0.7
# MACRO_SWING_MULTIPLIER_HIGH=0.5

# 当年成交缓存目录与刷新间隔（小时）
# TRADE_HISTORY_DIR=data/trade_history
# TRADE_HISTORY_CACHE_HOURS=12
# TRADE_RECENT_STOCK_COUNT=5
# TRADE_RECENT_OPTION_COUNT=5

# 股票中英文名称缓存（展示用，不发给 LLM）
# STOCK_NAMES_DIR=data/stock_names
# STOCK_NAMES_CACHE_HOURS=168
# STOCK_NAME_ZH_ENRICH=1

# ---------- K 线缓存（默认开启）----------
# KLINE_CACHE_ENABLED=1
# KLINE_CACHE_TTL_SEC=1500
# KLINE_ROUND_CACHE_TTL_SEC=600
# KLINE_WEEKLY_CACHE_TTL_SEC=14400
# KLINE_CACHE_DIR=data/kline_cache

# ---------- 决策与模拟数据目录（可选）----------
# 默认 data/decisions、data/payloads、data/sim，已在 .gitignore 中忽略
# DECISIONS_DIR=data/decisions
# PAYLOADS_DIR=data/payloads
# SIM_DATA_DIR=data/sim

# ---------- 日内 T+0 做 T 监控（可选）----------
# 支持港股与美股：HK.09988 / US.AAPL（纯数字默认港股，纯字母默认美股）
# 实时监控会按标的所属市场自动切换交易时段（港股北京时间 / 美股美东含夏令时）
# INTRADAY_T_CODE=HK.09988
# 多标的轮询监控（futu-intraday-watch）：逗号分隔，可港股/美股混合
# INTRADAY_T_CODES=HK.09988,US.AAPL
# INTRADAY_T_POLL_SEC=60   # 交易时段内轮询间隔（秒）
# INTRADAY_T_LOT_SIZE=1000          # 固定股数回退值（无持仓或 INTRADAY_T_LOT_PCT=0 时用）
# INTRADAY_T_LOT_PCT=30             # 按持仓比例自动折算整手；江铜 2000 股/每手 1000 → 50% = 1 手
# INTRADAY_T_TARGET_SPREAD=1.2
# INTRADAY_T_TARGET_SPREAD_AUTO=1   # 1=按手续费自动抬高目标价差下限
# INTRADAY_T_MIN_PROFIT_COST_RATIO=2.0   # 目标价差 ≥ 往返费用/股数 × 该倍数
# INTRADAY_T_US_COMMISSION_PER_SHARE=0.0049
# INTRADAY_T_US_MIN_COMMISSION=0.99
# INTRADAY_T_STATUS_INTERVAL_SEC=30
# INTRADAY_T_EVAL_TICK_SEC=2   # 本地补帧评估节拍：0=关闭；仅用最近一次 RT_DATA 的 price/vwap
# INTRADAY_T_RSI_SELL=75
# INTRADAY_T_RSI_BUY=35
# INTRADAY_T_VWAP_PREMIUM=1.015
# INTRADAY_T_VWAP_DISCOUNT=0.985   # 低吸：现价 < VWAP × 该值

# ---------- Bark 推送（日内做 T 信号通知 iPhone）----------
# BARK_ENABLED=1
# BARK_DEVICE_KEY=your_bark_device_key_from_bark_app   # 形如 https://api.day.app/<device_key>/推送内容
# BARK_SERVER=https://api.day.app
# BARK_GROUP=日内做T
# BARK_LEVEL=timeSensitive
# BARK_NOTIFY_WARNING=0

# SIM_INITIAL_CASH=1000000
# SIM_COMMISSION_RATE=0.0003
# SIM_MIN_COMMISSION=3
# SIM_PLATFORM_FEE=15
# SIM_STAMP_DUTY_RATE=0.0013
# SIM_EXECUTION_MODE=hybrid
# SIM_BACKEND=local
